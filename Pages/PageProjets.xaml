<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="app_test.Pages.PageProjets"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:app_test.Pages"
    xmlns:modeles="using:app_test"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.Resources>
            <!-- Là on crée un DataTemplate pour les éléments de notre GridView -->
            <DataTemplate x:Key="ProjeteGridView_ItemTemplate"
                  x:DataType="modeles:Projet">
                <Grid Name="MainGrid">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="auto"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0" Height="50"
                          Width="800"
                          Margin="8"
                          Background="Gray"
                          CornerRadius="5">
                        
                        <Grid x:Name="GridProjectText" 
                              Padding="4"
                              Width="700"
                              Height="50"
                              >
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="{x:Bind Name}"
                                       Style="{StaticResource BodyTextBlockStyle}"
                                       VerticalAlignment="Center"
                                       FontSize="20"    />
                            <TextBlock Grid.Column="1" Text="{x:Bind Description}"
                                       Style="{StaticResource BodyTextBlockStyle}" 
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Margin="50,0,0,0" Text="{x:Bind TimeLeft()}"
                                       Style="{StaticResource BodyTextBlockStyle}"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Grid>

                    <Grid Grid.Column="1" x:Name="ButtonDeleteGrid"
                          Height="50">
                        <StackPanel>
                            <Button Content="delete"
                            Background="Gray"
                            Height="50"
                            Click="OpenDeletePopUp">
                            </Button>
                        </StackPanel>
                        <Popup x:Name="DeletePopup">
                            <StackPanel>
                                <TextBlock Text="Voulez vous vraiment supprimer ce projet ? "></TextBlock>
                                <Grid Background="black">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Column="0" Content="Oui" Click="DeleteProject"></Button>
                                    <Button Grid.Column="1" Content="Non" Click="CloseDeletePopup"></Button>
                                </Grid>
                            </StackPanel>
                        </Popup>
                    </Grid>
                </Grid>
            </DataTemplate>
            
            <!-- Définis le style du container du gridView-->
            <Style x:Key="ProjetGridView_ItemContainerStyle"
                TargetType="GridViewItem">
            </Style>
                
            <!-- Sert  à dire comment est le panel qui acceuil / centre les rectangle au centre -->
            <ItemsPanelTemplate x:Key="ProjetGridView_Items_PanelTemplate">
                <ItemsWrapGrid Orientation="Horizontal"
                   HorizontalAlignment="Center"/>
            </ItemsPanelTemplate>
    
        </Grid.Resources>
        
        <!-- Definition de l'espace entre le button Create / StackPanel qui affiche le formulaire / GridView qui affiche la liste de projets-->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        
        <!-- Bouton qui sert à activé le formulaire -->
        <Button  Grid.Row="0" Content="Create Project" Click="ProjectClick" Margin="10,10,0,0" />

        <!-- Stack panel qui contient le formulaire -->
        <StackPanel Grid.Row="1" x:Name="CreateProjectPanel"
                    Visibility="Collapsed"
                    Padding="20">
            <StackPanel Orientation="Horizontal" Margin="0,0,0, 0">

                <TextBox x:Name="NameInput"
                             Header="Enter Project name:" PlaceholderText="Enter project name"
                             Width="300" HorizontalAlignment="Left"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,10,0, 20">

                <TextBox x:Name="DescriptionInput"
                             Header="Enter Project Description:" PlaceholderText="enter project description"
                             Width="300" HorizontalAlignment="Left"/>
            </StackPanel>
            <SplitButton x:Name="DeadlineButton">
                <SplitButton.Content>
                    <TextBlock x:Name="DeadLine_Text" 
                               Text="Chose your Deadline" Width="Auto" Height="Auto"/>
                </SplitButton.Content>
                <SplitButton.Flyout>
                    <MenuFlyout>
                        <MenuFlyoutItem Text="1 Semaine" Click="DeadlineItem_Click" Tag="7" />
                        <MenuFlyoutItem Text="1 Mois" Click="DeadlineItem_Click" Tag="30" />
                        <MenuFlyoutItem Text="6 Mois" Click="DeadlineItem_Click" Tag="180" />
                    </MenuFlyout>
                </SplitButton.Flyout>
            </SplitButton>

            <Button
                Margin="0,20,0,20"
                Content="Create"
                Click="CreateProject">
            </Button>
        </StackPanel>
        
        <!-- GridView qui affiche les projets -->
        <GridView Grid.Row="2" x:Name="ProjectGridView"
            ItemTemplate="{StaticResource ProjeteGridView_ItemTemplate}"
            ItemContainerStyle="{StaticResource ProjetGridView_ItemContainerStyle}"
            ItemsPanel="{StaticResource ProjetGridView_Items_PanelTemplate}"
            ItemsSource="{x:Bind Projets}"
            Margin= "100"
            IsItemClickEnabled = "True"
            ItemClick="OpenProject">
        </GridView>
    </Grid>
</Page>
